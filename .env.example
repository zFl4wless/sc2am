# Environment variables configuration example for sc2am
# Copy this file to .env and uncomment variables you want to customize

# Download directory for MP3 files
# SC2AM_DOWNLOAD_DIR=~/Downloads/sc2am

# Path to Apple Music library (auto-detected if not set)
# SC2AM_MUSIC_LIBRARY=/Users/yourusername/Music/Music/Media.localized

# Default playlist to add imported tracks to
# SC2AM_PLAYLIST="My Playlist"

# Keep downloaded MP3 files after import (true/false)
# SC2AM_KEEP_DOWNLOADS=true

# Automatically open Apple Music after download (true/false)
# SC2AM_OPEN_MUSIC=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
# SC2AM_LOG_LEVEL=INFO

# Path to log file (optional)
# SC2AM_LOG_FILE=~/sc2am.log

